{
  "name": "detox-rn-example",
  "version": "0.1.0",
  "private": true,
  "description": "Detox 20 + Jest starter for a React Native ~0.74 app",
  "scripts": {
    "build:ios": "detox build --configuration ios.sim.debug",
    "build:android": "detox build --configuration android.emu.debug",
    "test:ios": "detox test --configuration ios.sim.debug",
    "test:android": "detox test --configuration android.emu.debug"
  },
  "devDependencies": {
    "detox": "^20.20.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "detox": {
    "testRunner": {
      "args": {
        "$0": "jest",
        "config": "e2e/jest.config.js"
      },
      "jest": {
        "setupTimeout": 120000
      }
    }
  }
}
